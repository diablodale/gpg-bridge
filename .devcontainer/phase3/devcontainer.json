{
  // Phase 3 dev container — used by the automated integration test runner
  // (npm run test:integration:gpg-cli via gpgCliRunTest.ts, which passes configFile pointing here).
  // Also available in the VS Code manual container picker.
  //
  // Phase 3: gpg CLI in this container calls through gpg-bridge-request (workspace extension here)
  //   → VS Code commands → gpg-bridge-agent (Windows) → gpg-agent (Windows).
  //   The full chain: gpg → Unix socket → gpg-bridge-request → VS Code commands
  //   → gpg-bridge-agent (Windows) → gpg-agent (Windows).
  //
  // gpg2 (gnupg2) must be installed — test cases call the gpg binary directly.
  // GNUPGHOME is a static Linux path; the ASCII-armored public key for the Windows test
  // key is passed directly via PUBKEY_ARMORED_KEY env var (no file needed).
  //
  // See docs/integration-test-plan.md for details.
  "name": "request-phase-3-integration-tests",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "../../",
    // cacheFrom is advisory: Docker silently ignores it if the ghcr.io image is not
    // present locally. Local dev falls back to building from the MCR base image.
    // CI builds this image inline (docker/build-push-action) before running this
    // script so devcontainer up gets a full layer cache hit — no MCR download, no
    // npm install at container start.
    "cacheFrom": "ghcr.io/diablodale/gpg-bridge/devcontainer-request:phase3"
  },
  // remoteEnv is evaluated at attach time, not container creation.
  // ${localEnv:VAR} reads from the local VS Code process env — which is the
  // @vscode/test-electron-spawned VS Code process whose env = Object.assign({},
  // process.env, extensionTestsEnv). So extensionTestsEnv values already flow here.
  //
  // VSCODE_INTEGRATION_TEST: static flag — must be 1 for full extension init.
  // GNUPGHOME: static Linux path for the gpg CLI and GpgCli in the container.
  //   Distinct from Windows GNUPGHOME (which gpg-bridge-agent reads from extensionTestsEnv).
  // TEST_KEY_FINGERPRINT / PUBKEY_ARMORED_KEY: dynamic per run — generated in
  //   gpgCliRunTest.ts, injected into VS Code via extensionTestsEnv, resolved here
  //   via ${localEnv:...}.
  "remoteEnv": {
    "VSCODE_INTEGRATION_TEST": "1",
    "GNUPGHOME": "/tmp/gpg-test-phase3",
    "TEST_KEY_FINGERPRINT": "${localEnv:TEST_KEY_FINGERPRINT}",
    "PUBKEY_ARMORED_KEY": "${localEnv:PUBKEY_ARMORED_KEY}",
    // NODE_V8_COVERAGE causes the container's extension host Node process to write
    // raw V8 coverage JSON to this path on exit. The path is inside the workspace
    // bind mount so the JSON files are immediately accessible on the Windows host.
    // Phase 2 and Phase 3 both write to the same directory; Phase 2 clears it first
    // so that gpgCliRunTest.ts (Phase 3) processes the accumulated data from both.
    "NODE_V8_COVERAGE": "${containerWorkspaceFolder}/gpg-bridge-request/coverage/v8-integration"
  },
  // node_modules directories are shadowed by container-local Docker volumes so that
  // Linux-native symlinks (created by cp -a inside the container) do not touch the
  // Windows-host node_modules (which use NTFS junction points the Linux container
  // cannot follow). Use phase3-specific volume names to avoid conflicts with phase2
  // volumes if both containers are present.
  "mounts": [
    {
      "source": "gpg-bridge-p3-root-node-modules",
      "target": "${containerWorkspaceFolder}/node_modules",
      "type": "volume"
    },
    {
      "source": "gpg-bridge-p3-shared-node-modules",
      "target": "${containerWorkspaceFolder}/shared/node_modules",
      "type": "volume"
    },
    {
      "source": "gpg-bridge-p3-request-node-modules",
      "target": "${containerWorkspaceFolder}/gpg-bridge-request/node_modules",
      "type": "volume"
    },
    {
      "source": "gpg-bridge-p3-agent-node-modules",
      "target": "${containerWorkspaceFolder}/gpg-bridge-agent/node_modules",
      "type": "volume"
    }
  ],
  // gnupg2 is pre-installed in the base image.
  // updateContentCommand runs before VS Code connects (waitFor defaults to updateContentCommand),
  // so all npm packages are available before the extension host loads.
  // cp -a seeds each named volume from packages baked into the image at /opt/gpg-bridge-deps/.
  // The agent volume is empty (shadow only) — no agent packages run in the container.
  "updateContentCommand": "sudo chown node:node ${containerWorkspaceFolder}/node_modules ${containerWorkspaceFolder}/shared/node_modules ${containerWorkspaceFolder}/gpg-bridge-request/node_modules ${containerWorkspaceFolder}/gpg-bridge-agent/node_modules && cp -a /opt/gpg-bridge-deps/shared/node_modules/. ${containerWorkspaceFolder}/shared/node_modules/ && cp -a /opt/gpg-bridge-deps/gpg-bridge-request/node_modules/. ${containerWorkspaceFolder}/gpg-bridge-request/node_modules/",
  // VS Code Dev Containers unconditionally probes the Windows host for GPG configuration
  // at attach time and forwards any found agent socket + public keys into the container.
  // There is no setting to disable this behavior, so wiping the gpg homedir here
  // removes the pollution before extensions activate.
  //
  // waitFor: "postStartCommand" ensures VS Code does not attach (and therefore does not
  // forward the Windows GPG socket) until after the homedir wipe completes. Without this,
  // postStartCommand and extension activation race: the forwarded Windows socket is probe-
  // detected as 'live' by RequestProxy.start(), causing activation to throw.
  "waitFor": "postStartCommand",
  "postStartCommand": "echo '[postStartCommand] removing gpg homedir' && rm -rf \"$(gpgconf --list-dirs homedir)\"",
  "customizations": {
    "vscode": {
      "extensions": [
        // ESLint extension writes V8 coverage files that crash c8's fileURLToPath() on Linux-style file URLs.
        "-dbaeumer.vscode-eslint"
        // Both extensions are loaded as development extensions by the test runner;
        // no marketplace install is needed. Listed here for documentation.
        // "local.gpg-bridge-agent",   // loads on Windows (extensionKind: ui)
        // "local.gpg-bridge-request"  // loads here in container (extensionKind: workspace)
      ]
    }
  }
}
